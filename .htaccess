RewriteEngine On

# KİMLİKSİZ VE KENDİNİ GİZLEYEN ZARARLI BOTLARI ENGELLE (Sessiz Kalkan)
RewriteCond %{HTTP_USER_AGENT} ^$
RewriteRule ^ - [F,L]

# Force HTTPS
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://tevhid.tr%{REQUEST_URI} [R=301,L]

# Basic Security Headers
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set Referrer-Policy "strict-origin-when-cross-origin"

# Compression
AddOutputFilterByType DEFLATE text/plain text/html text/xml text/css text/javascript application/javascript application/json

# Cache Static Files - PageSpeed Optimized
<IfModule mod_expires.c>
  ExpiresActive On
  
  # Varsayılan süre (Tanımlanmamış her şey için 1 ay)
  ExpiresDefault "access plus 1 month"

  # HTML - Sayfa içeriği (1 gün - Güncellemelerin hızlı yansıması için kısa tuttuk)
  ExpiresByType text/html "access plus 1 day"

  # CSS ve JS (1 yıl - Google'ın en sevdiği değer)
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"

  # Görseller (İleride eklerseniz diye)
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"

  # Fontlar (Eğer sunucunda font dosyası varsa)
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>